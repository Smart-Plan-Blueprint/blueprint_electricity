  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function normalizeTransactionResponse() {",
          "  let json = {};",
          "  try {",
          "    json = pm.response.json();",
          "  } catch (error) {",
          "    console.warn('Response is not JSON', error);",
          "  }",
          "",
          "  const receipt = json.receiptItems || json.creditVendReceipt || {};",
          "  const totals = receipt.totals || {};",
          "  const meterDetails = receipt.meter_details || {};",
          "  const stdToken = Array.isArray(receipt.std_tokens) && receipt.std_tokens.length > 0 ? receipt.std_tokens[0] : {};",
          "",
          "  const normalized = {",
          "    transaction_id: pm.collectionVariables.get('trans_id') || pm.collectionVariables.get('client_sale_id') || receipt.external_reference_number || receipt.receipt_no || receipt.ReceiptNo || receipt.receiptNo || null,",
          "    amount: pm.collectionVariables.get('amount') || receipt.AmountTendered || totals.total || totals.tendered || receipt.amtTendered || null,",
          "    meter_number: pm.collectionVariables.get('meter_number') || meterDetails.number || receipt.meterNumber || null,",
          "    account_number: receipt.customer_account_no || receipt.account || null,",
          "    status: json.results || json.result || json.response || null,",
          "    message: json.message || null,",
          "    receipt_no: receipt.receipt_no || receipt.ReceiptNo || receipt.receiptNo || receipt.external_reference_number || null,",
          "    token: stdToken.code || receipt.stsCipher || null",
          "  };",
          "",
          "  pm.collectionVariables.set('last_transaction', JSON.stringify(normalized, null, 2));",
          "",
          "  if (normalized.account_number) {",
          "    pm.collectionVariables.set('account_number', normalized.account_number);",
          "  }",
          "",
          "  if (normalized.status) {",
          "    pm.test('Response has transaction status', function () {",
          "      pm.expect(normalized.status).to.exist;",
          "    });",
          "  }",
          "",
          "  console.log('Normalized portal transaction', normalized);",
          "}"
        ]
      }
    }
