    "_postman_id": "a5b2b4db-0b1c-4e55-8d64-0f3e2b646b64",
    "name": "Blueprint Electricity API",
    "description": "Postman collection for the Blueprint Electricity Laravel API.\n\nImportant: purchase endpoints can hit live electricity providers when the server is configured for production. Do not run purchase requests against production unless you intend to create a real transaction.\n\nThe collection stores useful response values in collection variables, including api_token, elec_token, customer_name, meter_number, and last_transaction.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Customer",
      "item": [
        {
          "name": "Verify Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try {",
                  "  json = pm.response.json();",
                  "} catch (error) {",
                  "  console.warn('Response is not JSON', error);",
                  "}",
                  "",
                  "if (json.api_token) {",
                  "  pm.collectionVariables.set('api_token', json.api_token);",
                  "}",
                  "",
                  "if (json.elec_token) {",
                  "  pm.collectionVariables.set('elec_token', json.elec_token);",
                  "}",
                  "",
                  "if (json.details) {",
                  "  if (json.details.customer_name) {",
                  "    pm.collectionVariables.set('customer_name', json.details.customer_name);",
                  "  }",
                  "  if (json.details.meter_number) {",
                  "    pm.collectionVariables.set('meter_number', json.details.meter_number);",
                  "  }",
                  "}",
                  "",
                  "pm.test('Response has transaction result', function () {",
                  "  pm.expect(json.results || json.result).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transID\": \"{{trans_id}}\",\n  \"meterNumber\": \"{{meter_number}}\",\n  \"amount\": {{amount}},\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/verifiyCustomer",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "verifiyCustomer"
              ]
            },
            "description": "Validates a customer and returns api_token, elec_token, customer_name, and meter_number when successful.\n\nRoute spelling is intentionally kept as implemented: /verifiyCustomer."
          },
          "response": []
        }
      ]
    },
